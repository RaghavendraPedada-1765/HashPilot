# HashPilot Backend — Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ────────────────────────────────────────────────────────────────
# SQLite (default). For PostgreSQL use: postgresql+psycopg2://user:pass@host/db
DATABASE_URL=sqlite:///./hashpilot.db

# ── ML Model ─────────────────────────────────────────────────────────────────
# Path to the pre-trained model artefacts (relative to the backend dir).
MODEL_PATH=app/ml/strategy_model.pkl
ENCODER_PATH=app/ml/label_encoder.pkl

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel URL when deploying to production.
ALLOWED_ORIGINS=http://localhost:5173

# ── Logging ──────────────────────────────────────────────────────────────────
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────────────────────
# Required for session signing if you add auth later.
SECRET_KEY=change-me-in-production
